// This is the Prisma schema for Food Mart - Meal Subscription Platform

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================
// ENUMS
// ============================================

enum UserRole {
  USER
  ADMIN
}

enum MealType {
  BREAKFAST
  LUNCH
  DINNER
}

enum DietaryType {
  VEG
  NON_VEG
  VEGAN
  EGGETARIAN
}

enum SpiceLevel {
  MILD
  MEDIUM
  HOT
  EXTRA_HOT
}

enum SubscriptionType {
  DAILY
  WEEKLY
  MONTHLY
}

enum SubscriptionStatus {
  ACTIVE
  PAUSED
  CANCELLED
  EXPIRED
  PENDING
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  REFUNDED
}

enum SubscriptionItemStatus {
  PENDING
  CONFIRMED
  PREPARED
  OUT_FOR_DELIVERY
  DELIVERED
  SKIPPED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum CouponType {
  PERCENTAGE
  FLAT
  FREE_MEAL
}

enum GiftCardStatus {
  ACTIVE
  PARTIALLY_USED
  FULLY_REDEEMED
  EXPIRED
  CANCELLED
}

enum ReferralStatus {
  PENDING
  COMPLETED
  EXPIRED
}

enum DeliveryTrackingStatus {
  PREPARING
  PICKED_UP
  IN_TRANSIT
  NEAR_DELIVERY
  DELIVERED
  FAILED
}

// ============================================
// AUTH & USER MODELS
// ============================================

model User {
  id              String    @id @default(cuid())
  name            String?
  email           String?   @unique
  emailVerified   DateTime?
  phone           String?   @unique
  phoneVerified   Boolean   @default(false)
  image           String?
  role            UserRole  @default(USER)
  referralCode    String    @unique @default(cuid())
  referredByCode  String?
  walletBalance   Float     @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  accounts        Account[]
  sessions        Session[]
  addresses       Address[]
  subscriptions   Subscription[]
  orders          Order[]
  payments        Payment[]
  couponUsages    CouponUsage[]
  giftCardsPurchased GiftCard[] @relation("PurchasedGiftCards")
  giftCardsRedeemed  GiftCard[] @relation("RedeemedGiftCards")
  referralsSent   Referral[] @relation("ReferrerReferrals")
  referralsReceived Referral[] @relation("RefereeReferrals")

  @@index([phone])
  @@index([email])
  @@index([referralCode])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model OtpVerification {
  id        String   @id @default(cuid())
  phone     String
  otp       String
  expiresAt DateTime
  attempts  Int      @default(0)
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([phone, otp])
  @@index([expiresAt])
}

// ============================================
// ADDRESS & DELIVERY MODELS
// ============================================

model Address {
  id           String   @id @default(cuid())
  userId       String
  label        String   @default("Home") // Home, Work, Other
  fullName     String
  phone        String
  addressLine1 String
  addressLine2 String?
  city         String
  state        String
  pincode      String
  landmark     String?
  latitude     Float?
  longitude    Float?
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]

  @@index([userId])
  @@index([pincode])
}

model DeliveryZone {
  id             String  @id @default(cuid())
  name           String
  pincodes       String[] // List of serviceable pincodes
  city           String
  state          String
  isActive       Boolean @default(true)
  deliveryCharge Float   @default(0)
  freeDeliveryAbove Float? // Free delivery above this order amount
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([city])
}

model DeliverySlot {
  id        String   @id @default(cuid())
  mealType  MealType
  startTime String   // "07:00" format
  endTime   String   // "09:00" format
  label     String   // e.g. "7:00 AM - 9:00 AM"
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)

  orders Order[]

  @@index([mealType])
}

// ============================================
// MENU & ITEM MODELS
// ============================================

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  image     String?
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  menuItems MenuItem[]

  @@index([slug])
}

model MenuItem {
  id            String      @id @default(cuid())
  name          String
  slug          String      @unique
  description   String      @db.Text
  image         String?
  basePrice     Float
  categoryId    String
  dietaryType   DietaryType @default(VEG)
  allergens     String[]    // e.g. ["nuts", "dairy", "gluten"]
  calories      Int?
  protein       Float?      // in grams
  carbs         Float?      // in grams
  fat           Float?      // in grams
  fiber         Float?      // in grams
  isGlutenFree  Boolean     @default(false)
  isJainFriendly Boolean    @default(false)
  spiceLevel    SpiceLevel  @default(MEDIUM)
  preparationTime Int?      // in minutes
  servingSize   String?     // e.g. "1 plate", "250ml"
  isActive      Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  category          Category           @relation(fields: [categoryId], references: [id])
  dailyMenuItems    DailyMenu[]
  subscriptionItems SubscriptionItem[]
  orderItems        OrderItem[]

  @@index([categoryId])
  @@index([slug])
  @@index([dietaryType])
  @@index([isActive])
}

model DailyMenu {
  id           String   @id @default(cuid())
  date         DateTime @db.Date
  mealType     MealType
  menuItemId   String
  isAvailable  Boolean  @default(true)
  specialPrice Float?   // Override price for the day
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())

  menuItem MenuItem @relation(fields: [menuItemId], references: [id])

  @@unique([date, mealType, menuItemId])
  @@index([date, mealType])
  @@index([menuItemId])
}

// ============================================
// SUBSCRIPTION MODELS
// ============================================

model SubscriptionPlan {
  id              String           @id @default(cuid())
  name            String           // e.g. "Daily Plan", "Weekly Saver", "Monthly Value"
  type            SubscriptionType
  durationDays    Int              // 1, 7, 30
  discountPercent Float            @default(0)
  description     String?          @db.Text
  features        String[]         // e.g. ["Free delivery", "Priority support"]
  isPopular       Boolean          @default(false)
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  subscriptions Subscription[]
}

model Subscription {
  id                      String             @id @default(cuid())
  userId                  String
  planId                  String
  status                  SubscriptionStatus @default(PENDING)
  startDate               DateTime
  endDate                 DateTime
  mealTypes               MealType[]
  razorpaySubscriptionId  String?            @unique
  isRecurring             Boolean            @default(false)
  autoRenew               Boolean            @default(false)
  totalAmount             Float
  pausedAt                DateTime?
  resumeDate              DateTime?
  cancelledAt             DateTime?
  cancellationReason      String?
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt

  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan              SubscriptionPlan   @relation(fields: [planId], references: [id])
  subscriptionItems SubscriptionItem[]
  orders            Order[]
  payments          Payment[]

  @@index([userId])
  @@index([status])
  @@index([startDate, endDate])
}

model SubscriptionItem {
  id             String                 @id @default(cuid())
  subscriptionId String
  date           DateTime               @db.Date
  mealType       MealType
  menuItemId     String
  quantity       Int                    @default(1)
  status         SubscriptionItemStatus @default(PENDING)
  skipReason     String?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  subscription     Subscription      @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  menuItem         MenuItem          @relation(fields: [menuItemId], references: [id])
  deliveryTracking DeliveryTracking?

  @@unique([subscriptionId, date, mealType, menuItemId])
  @@index([subscriptionId, date])
  @@index([menuItemId])
  @@index([status])
}

// ============================================
// ORDER & PAYMENT MODELS
// ============================================

model Order {
  id              String      @id @default(cuid())
  userId          String
  subscriptionId  String?
  orderNumber     String      @unique
  status          OrderStatus @default(PENDING)
  totalAmount     Float
  discountAmount  Float       @default(0)
  taxAmount       Float       @default(0)
  deliveryCharge  Float       @default(0)
  finalAmount     Float
  addressId       String?
  deliverySlotId  String?
  notes           String?     @db.Text
  couponCode      String?
  giftCardCode    String?
  giftCardAmount  Float       @default(0)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id])
  address      Address?      @relation(fields: [addressId], references: [id])
  deliverySlot DeliverySlot? @relation(fields: [deliverySlotId], references: [id])
  orderItems   OrderItem[]
  payments     Payment[]
  couponUsage  CouponUsage?

  @@index([userId])
  @@index([orderNumber])
  @@index([status])
  @@index([createdAt])
}

model OrderItem {
  id         String @id @default(cuid())
  orderId    String
  menuItemId String
  quantity   Int    @default(1)
  unitPrice  Float
  totalPrice Float
  mealType   MealType?

  order    Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem MenuItem @relation(fields: [menuItemId], references: [id])

  @@index([orderId])
  @@index([menuItemId])
}

model Payment {
  id                   String        @id @default(cuid())
  userId               String
  orderId              String?
  subscriptionId       String?
  giftCardId           String?
  amount               Float
  currency             String        @default("INR")
  status               PaymentStatus @default(PENDING)
  razorpayOrderId      String?       @unique
  razorpayPaymentId    String?       @unique
  razorpaySignature    String?
  razorpayInvoiceId    String?
  method               String?       // e.g. "card", "upi", "netbanking"
  description          String?
  refundId             String?
  refundAmount         Float?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  order        Order?        @relation(fields: [orderId], references: [id])
  subscription Subscription? @relation(fields: [subscriptionId], references: [id])
  giftCard     GiftCard?     @relation(fields: [giftCardId], references: [id])

  @@index([userId])
  @@index([razorpayOrderId])
  @@index([razorpayPaymentId])
  @@index([status])
}

// ============================================
// COUPON & GIFT CARD MODELS
// ============================================

model Coupon {
  id             String     @id @default(cuid())
  code           String     @unique
  type           CouponType
  value          Float      // Percentage or flat amount
  minOrderAmount Float?     // Minimum order to apply
  maxDiscount    Float?     // Max discount cap (for percentage coupons)
  usageLimit     Int?       // Total usage limit
  perUserLimit   Int        @default(1)
  usedCount      Int        @default(0)
  validFrom      DateTime
  validTill      DateTime
  description    String?
  isActive       Boolean    @default(true)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  usages CouponUsage[]

  @@index([code])
  @@index([validFrom, validTill])
  @@index([isActive])
}

model CouponUsage {
  id              String   @id @default(cuid())
  couponId        String
  userId          String
  orderId         String   @unique
  discountApplied Float
  usedAt          DateTime @default(now())

  coupon Coupon @relation(fields: [couponId], references: [id])
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  order  Order  @relation(fields: [orderId], references: [id])

  @@unique([couponId, userId, orderId])
  @@index([couponId])
  @@index([userId])
}

model GiftCard {
  id              String         @id @default(cuid())
  code            String         @unique @default(cuid())
  purchasedById   String
  redeemedById    String?
  amount          Float
  balance         Float
  status          GiftCardStatus @default(ACTIVE)
  recipientName   String?
  recipientEmail  String?
  recipientPhone  String?
  message         String?        @db.Text
  designTemplate  String         @default("classic")
  expiresAt       DateTime
  purchasedAt     DateTime       @default(now())
  redeemedAt      DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  purchasedBy User      @relation("PurchasedGiftCards", fields: [purchasedById], references: [id])
  redeemedBy  User?     @relation("RedeemedGiftCards", fields: [redeemedById], references: [id])
  payments    Payment[]

  @@index([code])
  @@index([purchasedById])
  @@index([redeemedById])
  @@index([status])
}

// ============================================
// REFERRAL MODEL
// ============================================

model Referral {
  id           String         @id @default(cuid())
  referrerId   String
  refereeId    String
  status       ReferralStatus @default(PENDING)
  rewardAmount Float          @default(0)
  rewardGiven  Boolean        @default(false)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  referrer User @relation("ReferrerReferrals", fields: [referrerId], references: [id])
  referee  User @relation("RefereeReferrals", fields: [refereeId], references: [id])

  @@unique([referrerId, refereeId])
  @@index([referrerId])
  @@index([refereeId])
}

// ============================================
// DELIVERY TRACKING MODEL
// ============================================

model DeliveryTracking {
  id                 String                 @id @default(cuid())
  subscriptionItemId String                 @unique
  status             DeliveryTrackingStatus @default(PREPARING)
  deliveryPartner    String?
  partnerPhone       String?
  estimatedTime      DateTime?
  actualDeliveryTime DateTime?
  currentLatitude    Float?
  currentLongitude   Float?
  notes              String?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt

  subscriptionItem SubscriptionItem @relation(fields: [subscriptionItemId], references: [id], onDelete: Cascade)

  @@index([status])
}

// ============================================
// APP SETTINGS MODEL
// ============================================

model AppSettings {
  id                   String  @id @default("default")
  appName              String  @default("Food Mart")
  taxRatePercent       Float   @default(5)
  freeDeliveryThreshold Float  @default(499)
  defaultDeliveryCharge Float  @default(49)
  referralRewardAmount Float   @default(100)
  referralRefereeBonus Float   @default(50)
  maxOtpAttempts       Int     @default(3)
  otpExpiryMinutes     Int     @default(5)
  giftCardValidityDays Int     @default(365)
  maintenanceMode      Boolean @default(false)
  updatedAt            DateTime @updatedAt
}
