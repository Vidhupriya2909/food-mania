# ==========================================
# Food Mart - Environment Variables
# ==========================================

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/foodmart?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-nextauth-secret-generate-with-openssl-rand-base64-32"

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Apple Sign-In
APPLE_ID=""
APPLE_TEAM_ID=""
APPLE_PRIVATE_KEY=""
APPLE_KEY_ID=""

# Razorpay
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""

# MSG91 (OTP)
MSG91_AUTH_KEY=""
MSG91_SENDER_ID=""
MSG91_TEMPLATE_ID=""
MSG91_OTP_TEMPLATE_ID=""

# Email (Nodemailer)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="noreply@foodmart.in"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Food Mart"
NEXT_PUBLIC_RAZORPAY_KEY_ID=""

# Referral
REFERRAL_REWARD_AMOUNT="100"

# Tax
TAX_RATE_PERCENT="5"
FREE_DELIVERY_THRESHOLD="499"
